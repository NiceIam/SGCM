# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sgcm_db
DB_USER=postgres
DB_PASSWORD=1234

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
